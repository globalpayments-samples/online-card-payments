# Global Payments API Credentials
# Get these from your Global Payments developer dashboard
# https://developer.globalpay.com/

# Application ID and Key
# These are required for authenticating with the Global Payments API
# You can find these in your Global Payments dashboard under "Apps"
GP_APP_ID=your_app_id_here
GP_APP_KEY=your_app_key_here

# Environment: sandbox or production
# Use 'sandbox' for testing, 'production' for live transactions
GP_ENVIRONMENT=sandbox

# Account Name (OPTIONAL - Leave commented out to let SDK auto-detect)
# The SDK will automatically use the correct account from your credentials
# Only uncomment this if you have multiple accounts and need to specify one
# GP_ACCOUNT_NAME=Transaction_Processing

# IMPORTANT NOTES:
# ----------------
# 1. Copy this file to .env and fill in your actual credentials
# 2. Never commit your .env file with real credentials to version control
# 3. The SDK handles token generation and account selection automatically
# 4. If you get "Access token and merchant info do not match" errors,
#    make sure GP_ACCOUNT_NAME is commented out (SDK auto-detection works best)
