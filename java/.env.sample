# GP-API Credentials (from developer.globalpay.com)
GP_APP_ID=your_app_id_here
GP_APP_KEY=your_app_key_here

# Environment: sandbox or production
GP_ENVIRONMENT=sandbox

# Merchant ID from the developer portal
GP_MERCHANT_ID=MER_your_merchant_id_here

# Account ID — TRA_ prefixed value for your channel
GP_ACCOUNT_ID=TRA_your_account_id_here

# Account name — must match portal EXACTLY (case-sensitive)
GP_ACCOUNT_NAME=transaction_processing

# 3DS2 Notification URLs
# For sandbox testing, use GP's hosted notification endpoints below.
# For local development you will need a public URL (e.g. via ngrok).
METHOD_NOTIFICATION_URL=https://developer.globalpayments.com/3ds2/method-notification
CHALLENGE_NOTIFICATION_URL=https://developer.globalpayments.com/3ds2/challenge-notification
